{
  "name": "convert-blob2image",
  "version": "1.0.0",
  "description": "Convert browser blob URLs (e.g. TikTok) to downloadable image files",
  "private": true,
  "scripts": {
    "build": "node scripts/build-bookmarklet.js",
    "build:drive": "node scripts/build-drive-console.js",
    "build:all": "npm run build && npm run build:drive",
    "serve": "npx serve ."
  },
  "dependencies": {
    "jspdf": "^3.0.1"
  },
  "devDependencies": {
    "terser": "^5.39.0"
  },
  "keywords": [
    "blob",
    "image",
    "converter",
    "tiktok",
    "bookmarklet"
  ],
  "author": "Manh Do",
  "license": "MIT"
}
